{
  "for i statement": {
    "prefix": "fori",
    "body": "for ${1:i} := ${2:0}; $1 < ${3:count}; $1${4:++} {\n\t$0\n}",
    "description": "Snippet for a for loop"
  },
  "http.ResponseWriter *http.Request": {
    "prefix": "wr",
    "body": "w http.ResponseWriter, r *http.Request",
    "description": "Snippet for http Response"
  },
  "switch statement": {
    "prefix": "switch",
    "body": "switch ${1:expression} {\ncase ${2:condition}:\n\t$0\n}",
    "description": "Snippet for switch statement"
  },
  "select statement": {
    "prefix": ["sel", "select"],
    "body": "select {\ncase ${1:condition}:\n\t$0\ndefault:}",
    "description": "Snippet for select statement"
  }
}
